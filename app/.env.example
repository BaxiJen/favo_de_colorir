# App Flutter usa APENAS URL + ANON_KEY.
# Service role/access token/db password NÃO devem ficar aqui — são
# credenciais administrativas e expõem o projeto inteiro se vazarem
# no APK. Ficam em supabase/.env.local (gitignored) pra uso com CLI.
SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
